OPENAI_API_KEY=
GEMINI_API_KEY=

PORT=4000

# LLM_PROVIDER: openai | deepseek | gemini | local  (default: openai)
LLM_PROVIDER=openai
# LLM_MODEL overrides the default per-provider model
LLM_MODEL=
# LLM_BASE_URL for 'local' provider (e.g. http://localhost:11434/v1)
LLM_BASE_URL=
# LLM_API_KEY for 'local' provider (most local servers don't need this)
LLM_API_KEY=
